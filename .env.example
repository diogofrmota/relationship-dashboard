# TMDB v3 API key. Read server-side by api/search.js, never exposed to the browser.
TMDB_API_KEY=your_tmdb_api_key_here

# Neon Postgres connection strings. Auto-provided by Vercel once the Neon
# integration is linked to the project. For local dev via `vercel dev`, pull
# them with `vercel env pull .env.local` instead of copying them by hand.
POSTGRES_URL=postgres://user:password@host/dbname
POSTGRES_URL_NON_POOLING=postgres://user:password@host/dbname
